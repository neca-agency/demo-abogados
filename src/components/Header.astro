---
import { firm, nav } from "../data/site";
---

<div class="site-header-shell">
	<header class="site-header">
		<div class="container site-header__inner">
			<a class="site-header__brand" href="/">
				<span class="site-header__name">{firm.name}</span>
				<span class="label-mono site-header__meta">{firm.location} · Desde {firm.founded}</span>
			</a>

			<nav class="site-header__nav" aria-label="Principal">
				<ul class="site-header__list">
					{
						nav.map((item) => (
							<li>
								<a href={item.href}>{item.label}</a>
							</li>
						))
					}
				</ul>
			</nav>

			<a class="btn btn--primary site-header__cta" href="#contacto">Contactar</a>
		</div>
	</header>

	<details class="site-header__menu">
		<summary class="site-header__menu-trigger" aria-label="Abrir menú de navegación">
			<span class="site-header__menu-icon" aria-hidden="true"></span>
		</summary>
		<div class="site-header__menu-panel" role="dialog" aria-modal="true" aria-label="Menú de navegación">
			<nav class="site-header__menu-nav" aria-label="Móvil">
				<ol class="site-header__menu-list">
					{
						nav.map((item, i) => (
							<li class="site-header__menu-item" style={`--i: ${i}`}>
								<a class="site-header__menu-link" href={item.href}>
									<span class="site-header__menu-index label-mono" aria-hidden="true">
										{String(i + 1).padStart(2, "0")}
									</span>
									<span class="site-header__menu-label">{item.label}</span>
								</a>
							</li>
						))
					}
				</ol>
			</nav>

			<div class="site-header__menu-footer">
				<a class="btn btn--primary site-header__menu-cta" href="#contacto">Contactar</a>
				<p class="site-header__menu-lead">
					Primera conversación sin compromiso · Respuesta en 24 h laborables
				</p>
			</div>
		</div>
	</details>
</div>

<script>
	const menu = document.querySelector<HTMLDetailsElement>(".site-header__menu");
	const trigger = menu?.querySelector<HTMLElement>(".site-header__menu-trigger");
	const summary = menu?.querySelector("summary");
	const panel = menu?.querySelector<HTMLElement>(".site-header__menu-panel");
	const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

	let closeTimer: ReturnType<typeof setTimeout> | undefined;
	let onPanelTransitionEnd: ((event: TransitionEvent) => void) | undefined;

	const syncMenuState = () => {
		const isActive = Boolean(menu?.open) && !menu?.classList.contains("is-closing");
		const isClosing = menu?.classList.contains("is-closing") ?? false;
		document.body.classList.toggle("menu-open", isActive || isClosing);
		trigger?.setAttribute(
			"aria-label",
			isActive || isClosing ? "Cerrar menú de navegación" : "Abrir menú de navegación",
		);
		trigger?.setAttribute("aria-expanded", String(isActive));
	};

	const clearCloseListeners = () => {
		clearTimeout(closeTimer);
		if (panel && onPanelTransitionEnd) {
			panel.removeEventListener("transitionend", onPanelTransitionEnd);
			onPanelTransitionEnd = undefined;
		}
	};

	const finishClose = () => {
		if (!menu) return;
		clearCloseListeners();
		menu.open = false;
		menu.classList.remove("is-closing");
		syncMenuState();
	};

	const cancelClose = () => {
		if (!menu?.classList.contains("is-closing")) return;
		clearCloseListeners();
		menu.classList.remove("is-closing");
		syncMenuState();
	};

	const startClose = () => {
		if (!menu?.open || menu.classList.contains("is-closing")) return;

		if (reducedMotion.matches) {
			finishClose();
			return;
		}

		clearCloseListeners();
		menu.classList.add("is-closing");
		syncMenuState();

		onPanelTransitionEnd = (event) => {
			if (event.target !== panel || event.propertyName !== "clip-path") return;
			finishClose();
		};

		panel?.addEventListener("transitionend", onPanelTransitionEnd);
		closeTimer = window.setTimeout(finishClose, 550);
	};

	summary?.addEventListener("click", (event) => {
		if (menu?.classList.contains("is-closing")) {
			event.preventDefault();
			cancelClose();
			return;
		}

		if (menu?.open) {
			event.preventDefault();
			startClose();
		}
	});

	menu?.addEventListener("toggle", () => {
		if (menu?.open) {
			menu.classList.remove("is-closing");
			clearCloseListeners();
		}
		syncMenuState();
	});

	menu?.querySelectorAll("a").forEach((link) => {
		link.addEventListener("click", startClose);
	});

	document.addEventListener("keydown", (event) => {
		if (event.key !== "Escape" || !menu?.open) return;
		event.preventDefault();
		if (menu.classList.contains("is-closing")) {
			cancelClose();
			return;
		}
		startClose();
	});
</script>

<style>
	.site-header-shell {
		--header-bar-height: 4.25rem;
		--menu-duration-enter: 420ms;
		--menu-duration-exit: 300ms;
		--menu-item-stagger-enter: 55ms;
		--menu-item-stagger-exit: 45ms;
		--menu-item-count: 4;
		position: sticky;
		top: 0;
		z-index: var(--z-sticky);
		isolation: isolate;
	}

	.site-header-shell:has(.site-header__menu[open]) {
		z-index: var(--z-modal);
	}

	.site-header {
		background: oklch(1 0 0 / 0.92);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--color-border);
	}

	.site-header-shell:has(.site-header__menu[open]) .site-header {
		background: var(--color-bg);
	}

	.site-header__inner {
		display: flex;
		align-items: center;
		gap: var(--space-lg);
		height: var(--header-bar-height);
		padding-right: calc(2.75rem + var(--space-md));
	}

	.site-header__brand {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		text-decoration: none;
		color: var(--color-ink);
		margin-right: auto;
	}

	.site-header__brand:hover {
		color: var(--color-ink);
	}

	.site-header__name {
		font-family: var(--font-display);
		font-size: 1.125rem;
		font-weight: 500;
		letter-spacing: -0.02em;
	}

	.site-header__meta {
		font-size: 0.6875rem;
	}

	.site-header__nav {
		display: none;
	}

	.site-header__list {
		display: flex;
		gap: var(--space-xl);
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.site-header__list a {
		font-size: var(--text-small);
		font-weight: 500;
		color: var(--color-ink);
		text-decoration: none;
	}

	.site-header__list a:hover {
		color: var(--color-primary);
	}

	.site-header__cta {
		display: none;
	}

	.site-header__menu {
		position: absolute;
		top: 0;
		right: var(--page-padding);
		height: var(--header-bar-height);
		display: flex;
		align-items: center;
		z-index: calc(var(--z-modal) + 1);
	}

	.site-header__menu-trigger {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		list-style: none;
		cursor: pointer;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-bg);
		transition:
			border-color var(--duration-fast) var(--ease-out-expo),
			background-color var(--duration-fast) var(--ease-out-expo);
	}

	.site-header__menu-trigger:hover {
		border-color: var(--color-ink);
	}

	.site-header__menu-trigger:focus-visible {
		outline: 2px solid var(--color-primary);
		outline-offset: 3px;
	}

	.site-header__menu-trigger::-webkit-details-marker {
		display: none;
	}

	.site-header__menu-icon,
	.site-header__menu-icon::before,
	.site-header__menu-icon::after {
		display: block;
		width: 1.125rem;
		height: 2px;
		background: var(--color-ink);
		position: relative;
		transition:
			transform var(--duration-base) var(--ease-out-expo),
			opacity var(--duration-base) var(--ease-out-expo);
	}

	.site-header__menu-icon::before,
	.site-header__menu-icon::after {
		content: "";
		position: absolute;
		left: 0;
	}

	.site-header__menu-icon::before {
		top: -6px;
	}

	.site-header__menu-icon::after {
		top: 6px;
	}

	.site-header__menu[open]:not(.is-closing) .site-header__menu-icon {
		background: transparent;
	}

	.site-header__menu[open]:not(.is-closing) .site-header__menu-icon::before {
		top: 0;
		transform: rotate(45deg);
	}

	.site-header__menu[open]:not(.is-closing) .site-header__menu-icon::after {
		top: 0;
		transform: rotate(-45deg);
	}

	.site-header__menu-panel {
		position: fixed;
		top: var(--header-bar-height);
		left: 0;
		right: 0;
		bottom: 0;
		width: 100%;
		z-index: var(--z-modal);
		display: flex;
		flex-direction: column;
		padding: var(--page-padding);
		padding-top: 0;
		padding-bottom: max(var(--space-xl), env(safe-area-inset-bottom));
		background: var(--color-bg);
		overflow-y: auto;
		overscroll-behavior: contain;
		opacity: 0;
		clip-path: inset(0 0 100% 0);
		visibility: hidden;
		pointer-events: none;
		transition:
			opacity var(--menu-duration-exit) var(--ease-out-expo),
			clip-path var(--menu-duration-exit) var(--ease-out-expo),
			visibility 0s linear var(--menu-duration-exit);
	}

	.site-header__menu[open]:not(.is-closing) .site-header__menu-panel {
		opacity: 1;
		clip-path: inset(0 0 0 0);
		visibility: visible;
		pointer-events: auto;
		transition:
			opacity var(--menu-duration-enter) var(--ease-out-expo),
			clip-path var(--menu-duration-enter) var(--ease-out-expo),
			visibility 0s linear 0s;
	}

	.site-header__menu.is-closing .site-header__menu-panel {
		pointer-events: none;
	}

	.site-header__menu-nav {
		flex: 1;
		display: flex;
		align-items: center;
		padding-block: var(--space-2xl);
	}

	.site-header__menu-list {
		list-style: none;
		margin: 0;
		padding: 0;
		width: 100%;
	}

	.site-header__menu-item {
		border-bottom: 1px solid var(--color-border);
		opacity: 0;
		transform: translateY(1.25rem);
		transition:
			opacity calc(var(--menu-duration-exit) * 0.85) var(--ease-out-expo),
			transform calc(var(--menu-duration-exit) * 0.85) var(--ease-out-expo);
		transition-delay: calc(
			(var(--menu-item-count) - 1 - var(--i, 0)) * var(--menu-item-stagger-exit)
		);
	}

	.site-header__menu-item:first-child {
		border-top: 1px solid var(--color-border);
	}

	.site-header__menu-link {
		display: grid;
		grid-template-columns: 3.5rem 1fr;
		align-items: baseline;
		gap: var(--space-md);
		padding-block: clamp(1.25rem, 4vw, 2rem);
		text-decoration: none;
		color: var(--color-ink);
		transition: color var(--duration-fast) var(--ease-out-expo);
	}

	.site-header__menu-link:hover,
	.site-header__menu-link:focus-visible {
		color: var(--color-primary);
	}

	.site-header__menu-index {
		padding-top: 0.35em;
	}

	.site-header__menu-label {
		font-family: var(--font-display);
		font-size: clamp(2rem, 7vw + 0.5rem, 3.25rem);
		font-weight: 400;
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-display);
		text-wrap: balance;
	}

	.site-header__menu[open]:not(.is-closing) .site-header__menu-item {
		opacity: 1;
		transform: translateY(0);
		transition:
			opacity var(--menu-duration-enter) var(--ease-out-expo),
			transform var(--menu-duration-enter) var(--ease-out-expo);
		transition-delay: calc(70ms + var(--i, 0) * var(--menu-item-stagger-enter));
	}

	.site-header__menu-footer {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		padding-top: var(--space-xl);
		border-top: 1px solid var(--color-border);
		opacity: 0;
		transform: translateY(0.875rem);
		transition:
			opacity var(--menu-duration-exit) var(--ease-out-expo),
			transform var(--menu-duration-exit) var(--ease-out-expo);
	}

	.site-header__menu[open]:not(.is-closing) .site-header__menu-footer {
		opacity: 1;
		transform: translateY(0);
		transition:
			opacity var(--menu-duration-enter) var(--ease-out-expo),
			transform var(--menu-duration-enter) var(--ease-out-expo);
		transition-delay: calc(70ms + var(--menu-item-count) * var(--menu-item-stagger-enter));
	}

	.site-header__menu-cta {
		width: 100%;
		min-height: 3.25rem;
		font-size: var(--text-body);
	}

	.site-header__menu-lead {
		margin: 0;
		font-size: var(--text-small);
		color: var(--color-muted);
		text-align: center;
		text-wrap: pretty;
	}

	@media (prefers-reduced-motion: reduce) {
		.site-header__menu-icon,
		.site-header__menu-icon::before,
		.site-header__menu-icon::after,
		.site-header__menu-panel,
		.site-header__menu-item,
		.site-header__menu-footer {
			transition: none;
		}

		.site-header__menu:not([open]) .site-header__menu-panel {
			opacity: 0;
			visibility: hidden;
		}

		.site-header__menu[open]:not(.is-closing) .site-header__menu-panel {
			opacity: 1;
			clip-path: inset(0 0 0 0);
			visibility: visible;
		}

		.site-header__menu[open]:not(.is-closing) .site-header__menu-item,
		.site-header__menu[open]:not(.is-closing) .site-header__menu-footer {
			opacity: 1;
			transform: none;
		}
	}

	@media (min-width: 56rem) {
		.site-header__inner {
			padding-right: 0;
		}

		.site-header__nav {
			display: block;
		}

		.site-header__cta {
			display: inline-flex;
		}

		.site-header__menu {
			display: none;
		}
	}
</style>
