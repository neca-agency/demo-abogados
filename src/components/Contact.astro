---
import { firm } from "../data/site";
---

<section id="contacto" class="section" aria-labelledby="contacto-heading">
	<div class="container contact">
		<div class="contact__intro">
			<h2 id="contacto-heading">Contacto</h2>
			<p class="prose contact__lead">
				La primera conversación es para entender vuestro caso. Sin formularios intrusivos ni compromiso previo.
			</p>

			<address class="contact__details">
				<p>{firm.address}</p>
				<p>
					<a href={`tel:${firm.phone.replace(/\s/g, "")}`}>{firm.phone}</a>
				</p>
				<p>
					<a href={`mailto:${firm.email}`}>{firm.email}</a>
				</p>
			</address>
		</div>

		<form
			class="contact__form"
			method="post"
			action="#"
			novalidate
			data-contact-form
			aria-describedby="form-status"
		>
			<div class="contact__field">
				<label for="nombre">Nombre</label>
				<input id="nombre" name="nombre" type="text" autocomplete="name" required />
			</div>

			<div class="contact__field">
				<label for="email">Correo electrónico</label>
				<input id="email" name="email" type="email" autocomplete="email" required />
			</div>

			<div class="contact__field">
				<label for="asunto">Asunto</label>
				<input id="asunto" name="asunto" type="text" required />
			</div>

			<div class="contact__field">
				<label for="mensaje">Mensaje</label>
				<textarea id="mensaje" name="mensaje" rows="5" required></textarea>
			</div>

			<p id="form-status" class="contact__status" role="status" aria-live="polite" hidden data-form-status></p>

			<button class="btn btn--primary" type="submit">Enviar mensaje</button>
		</form>
	</div>
</section>

<script>
	const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
	const status = document.querySelector<HTMLElement>("[data-form-status]");

	form?.addEventListener("submit", (event) => {
		event.preventDefault();

		if (!form || !status) return;

		if (!form.checkValidity()) {
			status.hidden = false;
			status.textContent = "Revisad los campos marcados antes de enviar.";
			status.dataset.state = "error";
			form.reportValidity();
			return;
		}

		status.hidden = false;
		status.textContent =
			"Gracias por vuestro mensaje. En un entorno real, lo recibiríamos en las próximas horas laborables.";
		status.dataset.state = "success";
		form.reset();
	});
</script>

<style>
	.contact {
		display: grid;
		gap: var(--space-2xl);
		align-items: start;
	}

	.contact__intro {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
	}

	.contact__lead {
		color: var(--color-muted);
	}

	.contact__details {
		font-style: normal;
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		font-size: var(--text-small);
	}

	.contact__details a {
		color: var(--color-ink);
		text-decoration: none;
		font-weight: 600;
	}

	.contact__details a:hover {
		color: var(--color-primary);
	}

	.contact__form {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
		padding: var(--space-xl);
		background: var(--color-surface);
		border-radius: var(--radius-lg);
	}

	.contact__field {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.contact__field label {
		font-size: var(--text-small);
		font-weight: 600;
	}

	.contact__field input,
	.contact__field textarea {
		font-family: var(--font-body);
		font-size: var(--text-body);
		color: var(--color-ink);
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		padding: 0.75rem 0.875rem;
		transition: border-color var(--duration-fast) var(--ease-out-expo);
	}

	.contact__field input::placeholder,
	.contact__field textarea::placeholder {
		color: var(--color-muted);
	}

	.contact__field input:focus,
	.contact__field textarea:focus {
		outline: none;
		border-color: var(--color-primary);
		box-shadow: 0 0 0 3px var(--ring-primary);
	}

	.contact__field input:user-invalid:not(:placeholder-shown),
	.contact__field textarea:user-invalid:not(:placeholder-shown) {
		border-color: var(--color-error);
	}

	.contact__field textarea {
		resize: vertical;
		min-height: 7rem;
	}

	.contact__status[data-state="error"] {
		color: var(--color-error);
		font-size: var(--text-small);
	}

	.contact__status[data-state="success"] {
		color: var(--color-ink);
		font-size: var(--text-small);
	}

	@media (min-width: 56rem) {
		.contact {
			grid-template-columns: 1fr 1.1fr;
			gap: clamp(2rem, 6vw, 5rem);
		}
	}
</style>
