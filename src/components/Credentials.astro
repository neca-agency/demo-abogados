---
import { credentials } from "../data/site";
---

<section class="section" aria-labelledby="credenciales-heading">
	<div class="container credentials">
		<h2 id="credenciales-heading">{credentials.title}</h2>

		<div class="credentials__grid">
			<ul class="credentials__list">
				{
					credentials.items.map((item) => (
						<li class="credentials__item">
							<p class="credentials__label">{item.label}</p>
							<p class="credentials__detail">{item.detail}</p>
						</li>
					))
				}
			</ul>

			<div class="credentials__quotes">
				{
					credentials.quotes.map((quote) => (
						<figure class="credentials__quote">
							<blockquote>
								<p>{quote.text}</p>
							</blockquote>
							<figcaption class="label-mono">{quote.attribution}</figcaption>
						</figure>
					))
				}
			</div>
		</div>
	</div>
</section>

<style>
	.credentials {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xl);
	}

	.credentials__grid {
		display: grid;
		gap: var(--space-2xl);
	}

	.credentials__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
	}

	.credentials__item {
		padding-block: var(--space-lg);
		border-bottom: 1px solid var(--color-border);
	}

	.credentials__item:first-child {
		border-top: 1px solid var(--color-border);
	}

	.credentials__label {
		font-weight: 600;
		margin-bottom: var(--space-xs);
	}

	.credentials__detail {
		color: var(--color-muted);
		font-size: var(--text-small);
		max-width: 40ch;
	}

	.credentials__quotes {
		display: flex;
		flex-direction: column;
		gap: var(--space-xl);
	}

	.credentials__quote {
		margin: 0;
		padding: var(--space-lg);
		background: var(--color-surface);
		border-radius: var(--radius-lg);
	}

	.credentials__quote blockquote {
		margin: 0 0 var(--space-md);
	}

	.credentials__quote p {
		font-family: var(--font-display);
		font-size: 1.125rem;
		line-height: 1.45;
		color: var(--color-ink);
	}

	@media (min-width: 56rem) {
		.credentials__grid {
			grid-template-columns: 1fr 1fr;
			gap: clamp(2rem, 5vw, 4rem);
			align-items: start;
		}
	}
</style>
