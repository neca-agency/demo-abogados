---
import { credentials } from "../data/site";
import QuoteAltLeft from "./icons/QuoteAltLeft.astro";

const [featuredQuote, secondaryQuote] = credentials.quotes;
---

<section class="section" aria-labelledby="credenciales-heading">
	<div class="container credentials">
		<div class="credentials__stage">
			<header class="credentials__header">
				<h2 id="credenciales-heading">{credentials.title}</h2>
			</header>

			<div class="credentials__voice">
				<figure class="credentials__featured">
					<span class="credentials__mark" aria-hidden="true">
						<QuoteAltLeft class="credentials__mark-svg" />
					</span>
					<blockquote class="credentials__statement">
						<p>{featuredQuote.text}</p>
					</blockquote>
					<figcaption class="label-mono credentials__attribution">{featuredQuote.attribution}</figcaption>
				</figure>

				<figure class="credentials__aside">
					<blockquote class="credentials__pull">
						<p>{secondaryQuote.text}</p>
					</blockquote>
					<figcaption class="label-mono credentials__attribution">{secondaryQuote.attribution}</figcaption>
				</figure>
			</div>

			<aside class="credentials__registry" aria-label="Reconocimientos del estudio">
				<ul class="credentials__list">
					{
						credentials.items.map((item) => (
							<li class="credentials__item">
								<p class="credentials__source">{item.label}</p>
								<p class="credentials__detail">{item.detail}</p>
							</li>
						))
					}
				</ul>
			</aside>
		</div>
	</div>
</section>

<style>
	.credentials__stage {
		display: grid;
		gap: var(--space-xl);
	}

	.credentials__header {
		min-width: 0;
	}

	.credentials__voice {
		display: flex;
		flex-direction: column;
		gap: var(--space-xl);
		min-width: 0;
	}

	.credentials__featured,
	.credentials__aside {
		margin: 0;
	}

	.credentials__featured {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
		max-width: 34rem;
	}

	.credentials__mark {
		display: block;
		width: clamp(2.75rem, 3vw + 1.5rem, 4rem);
		color: var(--color-accent-soft);
		line-height: 0;
		user-select: none;
	}

	.credentials__mark-svg {
		display: block;
		width: 100%;
		height: auto;
	}

	.credentials__statement,
	.credentials__pull {
		margin: 0;
		padding: 0;
		border: 0;
	}

	.credentials__statement p {
		font-family: var(--font-display);
		font-size: clamp(1.5rem, 1.8vw + 0.9rem, 2.35rem);
		font-weight: 400;
		line-height: 1.24;
		letter-spacing: var(--tracking-display);
		text-wrap: balance;
		color: var(--color-ink);
	}

	.credentials__aside {
		max-width: 30rem;
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-border);
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.credentials__pull p {
		font-family: var(--font-display);
		font-size: clamp(1.0625rem, 0.35vw + 0.98rem, 1.1875rem);
		font-style: italic;
		font-weight: 400;
		line-height: 1.45;
		letter-spacing: -0.02em;
		text-wrap: pretty;
		color: var(--color-ink);
	}

	.credentials__attribution {
		margin: 0;
	}

	.credentials__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0;
	}

	.credentials__item {
		padding-block: var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}

	.credentials__item:first-child {
		border-top: 1px solid var(--color-border);
	}

	.credentials__source {
		margin: 0 0 var(--space-xs);
		font-family: var(--font-display);
		font-size: clamp(1rem, 0.25vw + 0.92rem, 1.125rem);
		font-weight: 500;
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-display);
		color: var(--color-ink);
	}

	.credentials__detail {
		margin: 0;
		font-size: var(--text-small);
		line-height: 1.45;
		color: var(--color-muted);
		text-wrap: pretty;
	}

	@media (min-width: 40rem) {
		.credentials__list {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			column-gap: var(--space-lg);
		}

		.credentials__item {
			border-top: none;
			border-bottom: none;
			padding-block: 0;
			padding-inline-end: var(--space-lg);
			border-inline-end: 1px solid var(--color-border);
		}

		.credentials__item:first-child {
			border-top: none;
		}

		.credentials__item:last-child {
			border-inline-end: none;
			padding-inline-end: 0;
		}
	}

	@media (min-width: 48rem) {
		.credentials__stage {
			grid-template-columns: minmax(0, 1fr) minmax(12.5rem, 17.5%);
			grid-template-rows: auto 1fr;
			column-gap: clamp(2.5rem, 6vw, 5rem);
			row-gap: var(--space-2xl);
			align-items: start;
		}

		.credentials__header {
			grid-column: 1;
			grid-row: 1;
		}

		.credentials__voice {
			grid-column: 1;
			grid-row: 2;
			gap: clamp(2rem, 4vw, 3rem);
			padding-bottom: var(--space-sm);
		}

		.credentials__registry {
			grid-column: 2;
			grid-row: 1 / -1;
			padding-left: clamp(1.25rem, 2.5vw, 2.25rem);
			border-left: 1px solid var(--color-border);
		}

		.credentials__list {
			grid-template-columns: 1fr;
			gap: 0;
		}

		.credentials__item {
			padding-block: var(--space-md);
			padding-inline-end: 0;
			border-inline-end: none;
			border-bottom: 1px solid var(--color-border);
		}

		.credentials__item:first-child {
			padding-top: 0;
			border-top: none;
		}

		.credentials__item:last-child {
			border-bottom: none;
		}
	}

	@media (min-width: 64rem) {
		.credentials__featured {
			max-width: 36rem;
		}

		.credentials__statement p {
			font-size: clamp(1.75rem, 1.4vw + 1rem, 2.5rem);
		}
	}
</style>
