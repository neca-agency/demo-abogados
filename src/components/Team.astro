---
import { team } from "../data/site";
---

<section id="equipo" class="section section--surface" aria-labelledby="equipo-heading">
	<div class="container team">
		<div class="team__header">
			<h2 id="equipo-heading">Equipo</h2>
			<p class="prose team__lead">
				Tres socios, un criterio compartido. Conocéis a quien lleva vuestro expediente desde el primer día.
			</p>
		</div>

		<ul class="team__grid">
			{
				team.map((member) => (
					<li class="team__card">
						<figure class="team__media">
							<img
								src={member.image.src}
								alt={member.image.alt}
								width="600"
								height="450"
								loading="lazy"
								decoding="async"
							/>
						</figure>
						<div class="team__info">
							<h3>{member.name}</h3>
							<p class="team__role">{member.role}</p>
							<p class="label-mono team__credential">{member.credential}</p>
						</div>
					</li>
				))
			}
		</ul>
	</div>
</section>

<style>
	.team {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xl);
	}

	.team__header {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		max-width: 32rem;
	}

	.team__lead {
		color: var(--color-muted);
	}

	.team__grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: var(--space-2xl);
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
	}

	.team__card {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
	}

	.team__media {
		margin: 0;
		border-radius: var(--radius-lg);
		overflow: hidden;
		aspect-ratio: 4 / 3;
	}

	.team__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 20%;
	}

	.team__info {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.team__role {
		color: var(--color-muted);
		font-size: var(--text-small);
	}

	.team__credential {
		margin-top: var(--space-xs);
		line-height: 1.5;
	}
</style>
