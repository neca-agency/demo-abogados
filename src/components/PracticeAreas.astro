---
import { practiceAreas } from "../data/site";
---

<section id="areas" class="section section--surface section--below-fold" aria-labelledby="areas-heading">
	<div class="container areas" data-areas-accordion>
		<header class="areas__intro">
			<p class="label-mono areas__label">Práctica</p>
			<h2 id="areas-heading">Áreas de práctica</h2>
			<p class="prose areas__lead">
				Cinco disciplinas con profundidad real. Sin listados genéricos ni promesas vacías — cada área tiene un socio
				responsable y criterio propio.
			</p>
		</header>

		<ol class="areas__stack">
			{
				practiceAreas.map((area) => (
					<li class="areas__stack-item">
						<details class="areas__item">
							<summary class="areas__summary">
								<span class="label-mono areas__index" aria-hidden="true">
									{area.index}
								</span>
								<span class="areas__title">{area.title}</span>
								<span class="areas__marker" aria-hidden="true" />
							</summary>
							<div class="areas__panel" data-areas-panel>
							<div class="areas__panel-inner">
								<div class="areas__panel-body">
									<p>{area.description}</p>
								</div>
							</div>
							</div>
						</details>
					</li>
				))
			}
		</ol>
	</div>
</section>

<script>
	import { initDetailsAccordion } from "../scripts/details-accordion";
	import { lazyInitWhenVisible } from "../scripts/lazy-init";

	const areasAccordionConfig = {
		itemSelector: ".areas__item",
		summarySelector: ".areas__summary",
		panelSelector: "[data-areas-panel]",
		innerSelector: ".areas__panel-inner",
	} as const;

	const areas = document.querySelector<HTMLElement>("[data-areas-accordion]");
	if (areas) {
		const cleanup = lazyInitWhenVisible(areas, () => initDetailsAccordion(areas, areasAccordionConfig));
		document.addEventListener(
			"astro:before-swap",
			() => {
				cleanup();
			},
			{ once: true },
		);
	}
</script>

<style>
	.areas {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xl);
	}

	.areas__intro {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		max-width: 32rem;
	}

	.areas__label {
		color: var(--color-muted);
	}

	.areas__lead {
		color: var(--color-muted);
	}

	.areas__stack {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		border-top: 1px solid var(--color-border);
	}

	.areas__stack-item {
		border-bottom: 1px solid var(--color-border);
	}

	.areas__item {
		border: 0;
	}

	.areas__summary {
		display: grid;
		grid-template-columns: 2.25rem 1fr auto;
		gap: var(--space-md);
		align-items: start;
		padding-block: clamp(var(--space-md), 2vw, var(--space-lg));
		cursor: pointer;
		list-style: none;
		border-radius: var(--radius-sm);
	}

	.areas__item[open] .areas__summary {
		padding-bottom: var(--space-xs);
	}

	.areas__summary:focus-visible {
		outline: 2px solid var(--color-primary);
		outline-offset: 2px;
	}

	.areas__summary::-webkit-details-marker {
		display: none;
	}

	.areas__index {
		padding-top: 0.2em;
		line-height: 1;
		align-self: start;
	}

	.areas__title {
		font-family: var(--font-display);
		font-size: clamp(1.375rem, 1.75vw + 0.85rem, 2.125rem);
		font-weight: 400;
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-display);
		text-wrap: balance;
		min-width: 0;
	}

	.areas__marker {
		font-family: var(--font-mono);
		font-size: clamp(1.75rem, 2.25vw + 0.75rem, 2.5rem);
		font-weight: 300;
		color: var(--color-primary);
		line-height: 1;
		flex-shrink: 0;
		min-width: 1.5rem;
		text-align: center;
		padding-top: 0.1em;
	}

	.areas__marker::before {
		content: "+";
	}

	.areas__item[open] .areas__marker::before {
		content: "−";
	}

	.areas__panel {
		overflow: hidden;
	}

	.areas__panel-inner {
		display: grid;
		grid-template-columns: 2.25rem 1fr;
		gap: var(--space-md);
		padding-bottom: clamp(var(--space-md), 2vw, var(--space-lg));
	}

	.areas__panel-body {
		grid-column: 2;
		min-width: 0;
	}

	.areas__panel-body p {
		color: var(--color-muted);
		font-size: var(--text-body);
		line-height: 1.65;
		max-width: 58ch;
		min-width: 0;
	}

	@media (min-width: 48rem) {
		.areas__summary {
			grid-template-columns: 2.75rem 1fr auto;
			gap: var(--space-md);
			padding-block: clamp(var(--space-lg), 2vw, var(--space-xl));
		}

		.areas__index {
			padding-top: 0.3em;
		}

		.areas__panel-inner {
			grid-template-columns: 2.75rem 1fr;
			gap: var(--space-md);
			padding-bottom: clamp(var(--space-lg), 2vw, var(--space-xl));
		}
	}

</style>
