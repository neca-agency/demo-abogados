---
import { firm, hero } from "../data/site";
import {
	heroDesktopSrcset,
	heroImageUrl,
	heroMobileSrcset,
	heroTabletSrcset,
} from "../utils/hero-image";

const metaText = `${firm.location} · Desde ${firm.founded}`;
const headlineWords = hero.headline.split(/\s+/);
const subheadLines = hero.subhead.split(/(?<=\.)\s+/);
---

<section class="hero section" aria-labelledby="hero-heading" data-hero>
	<div class="container hero__grid">
		<figure class="hero__media">
			<div class="hero__media-inner">
				<picture>
					<source
						media="(min-width: 56rem)"
						srcset={heroDesktopSrcset}
						sizes="42vw"
						width="1200"
						height="1500"
					/>
					<source
						media="(min-width: 40rem)"
						srcset={heroTabletSrcset}
						sizes="100vw"
						width="1200"
						height="800"
					/>
					<img
						src={heroImageUrl(480, 384)}
						srcset={heroMobileSrcset}
						sizes="100vw"
						alt={hero.image.alt}
						width="480"
						height="384"
						fetchpriority="high"
						decoding="async"
					/>
				</picture>
			</div>
		</figure>

		<div class="hero__content">
			<p class="label-mono hero__meta" aria-label={metaText}>
				<span class="hero__meta-text" aria-hidden="true">
					{
						[...metaText].map((char) => (
							<span class="hero__meta-char">{char === " " ? "\u00a0" : char}</span>
						))
					}
				</span>
				<span class="hero__meta-rule" aria-hidden="true"></span>
			</p>
			<h1 id="hero-heading" class="hero__headline">
				<span class="hero__headline-line">
					{
						headlineWords.map((word) => (
							<span class="hero__word">
								<span class="hero__word-inner">{word}</span>
							</span>
						))
					}
				</span>
			</h1>
			<div class="hero__subhead prose">
				{
					subheadLines.map((line) => (
						<p class="hero__subhead-line">
							<span class="hero__subhead-line-inner">{line}</span>
						</p>
					))
				}
			</div>
			<div class="hero__actions">
				<a class="btn btn--primary" href="#contacto">{hero.cta}</a>
				<a class="link-text" href="#areas">{hero.ctaSecondary}</a>
			</div>
		</div>
	</div>
</section>

<script>
	import { initHeroMotion } from "../scripts/hero-motion";

	const hero = document.querySelector<HTMLElement>("[data-hero]");
	if (hero) {
		const cleanup = initHeroMotion(hero);
		document.addEventListener(
			"astro:before-swap",
			() => {
				cleanup();
			},
			{ once: true },
		);
	}
</script>

<style>
	.hero {
		padding-block: clamp(1.25rem, 3vw, 4rem) clamp(2.5rem, 8vw, var(--space-3xl));
	}

	.hero__grid {
		display: grid;
		gap: clamp(1.5rem, 4vw, var(--space-2xl));
		align-items: start;
	}

	.hero__media,
	.hero__content {
		min-width: 0;
	}

	.hero__media {
		--hero-image-position: 50% 22%;
		margin: 0;
		order: 1;
		overflow: hidden;
		border-radius: var(--radius-lg);
		aspect-ratio: 5 / 4;
	}

	.hero__media-inner {
		width: 100%;
		height: 100%;
		will-change: transform;
	}

	.hero__media-inner picture,
	.hero__media-inner img {
		display: block;
		width: 100%;
		height: 100%;
	}

	.hero__media-inner img {
		object-fit: cover;
		object-position: var(--hero-image-position);
	}

	.hero__content {
		order: 0;
		display: flex;
		flex-direction: column;
		gap: clamp(1rem, 2.5vw, var(--space-lg));
	}

	.hero__meta {
		margin: 0;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.65rem;
	}

	.hero__meta-rule {
		display: block;
		width: min(12rem, 42vw);
		height: 1px;
		background: var(--color-border);
	}

	.hero__meta-char {
		display: inline-block;
	}

	.hero__headline {
		margin: 0;
		font-size: clamp(2rem, 6.5vw + 0.75rem, var(--text-display));
		font-weight: 400;
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-display);
		text-wrap: balance;
		overflow-wrap: anywhere;
		hyphens: auto;
	}

	.hero__headline-line {
		display: block;
	}

	.hero__word {
		display: inline-block;
		overflow: visible;
		vertical-align: top;
		margin-inline-end: 0.28em;
	}

	.hero__word:last-child {
		margin-inline-end: 0;
	}

	.hero--js .hero__word {
		overflow: hidden;
	}

	.hero__word-inner {
		display: inline-block;
		will-change: transform;
	}

	.hero__subhead {
		display: flex;
		flex-direction: column;
		gap: 0.65em;
		font-size: clamp(1rem, 0.5vw + 0.95rem, 1.1875rem);
		color: var(--color-muted);
		max-width: min(38ch, 100%);
		text-wrap: pretty;
	}

	.hero__subhead-line {
		margin: 0;
		overflow: visible;
	}

	.hero--js .hero__subhead-line {
		overflow: hidden;
	}

	.hero__subhead-line-inner {
		display: block;
		will-change: transform, opacity;
	}

	.hero__actions {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: var(--space-md);
		margin-top: var(--space-xs);
	}

	.hero__actions .btn {
		width: 100%;
	}

	.hero__actions .link-text {
		align-self: center;
		text-align: center;
	}

	@media (pointer: coarse) {
		.hero__actions .link-text {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-height: 2.75rem;
			padding-inline: var(--space-sm);
		}
	}

	@media (min-width: 30rem) {
		.hero__actions {
			flex-flow: row wrap;
			align-items: center;
		}

		.hero__actions .btn {
			width: auto;
		}

		.hero__actions .link-text {
			align-self: auto;
			text-align: inherit;
		}
	}

	@media (min-width: 40rem) {
		.hero__media {
			--hero-image-position: 50% 28%;
			aspect-ratio: 3 / 2;
			max-width: 38rem;
			margin-inline: auto;
		}
	}

	@media (min-width: 40rem) and (orientation: landscape) and (max-width: 55.99rem) {
		.hero__media {
			--hero-image-position: 50% 32%;
			aspect-ratio: 16 / 9;
			max-width: none;
		}
	}

	@media (min-width: 56rem) {
		.hero__grid {
			grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
			gap: clamp(2rem, 5vw, 4.5rem);
			align-items: center;
		}

		.hero__media {
			--hero-image-position: 50% 30%;
			order: -1;
			aspect-ratio: 4 / 5;
			max-width: none;
			margin-inline: 0;
			max-height: 36rem;
		}

		.hero__content {
			order: 0;
		}

		.hero__subhead {
			max-width: 38ch;
		}
	}

	@media (min-width: 56rem) and (max-height: 48rem) {
		.hero {
			padding-block: clamp(1rem, 2vw, 2rem) var(--space-2xl);
		}

		.hero__media {
			max-height: min(28rem, 72vh);
		}

		.hero__headline {
			font-size: clamp(2rem, 3.5vw + 0.5rem, 3.25rem);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero__media-inner,
		.hero__word-inner,
		.hero__subhead-line-inner,
		.hero__meta-char,
		.hero__actions {
			will-change: auto;
		}
	}
</style>
