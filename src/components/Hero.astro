---
import { firm, hero } from "../data/site";
---

<section class="hero section" aria-labelledby="hero-heading">
	<div class="container hero__grid hero-animate">
		<figure class="hero__media">
			<img
				src={hero.image.src}
				alt={hero.image.alt}
				width="1200"
				height="1500"
				fetchpriority="high"
				decoding="async"
			/>
		</figure>

		<div class="hero__content">
			<p class="label-mono hero__meta">
				{firm.location} · Desde {firm.founded}
			</p>
			<h1 id="hero-heading">{hero.headline}</h1>
			<p class="hero__subhead prose">{hero.subhead}</p>
			<div class="hero__actions">
				<a class="btn btn--primary" href="#contacto">{hero.cta}</a>
				<a class="link-text" href="#areas">{hero.ctaSecondary}</a>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		padding-block: clamp(2rem, 5vw, 4rem) var(--space-3xl);
	}

	.hero__grid {
		display: grid;
		gap: var(--space-2xl);
		align-items: center;
	}

	.hero__media,
	.hero__content {
		min-width: 0;
	}

	.hero__media {
		margin: 0;
		overflow: hidden;
		border-radius: var(--radius-lg);
		aspect-ratio: 4 / 5;
		max-height: 36rem;
	}

	.hero__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 30%;
	}

	.hero__content {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
	}

	.hero__subhead {
		font-size: clamp(1.0625rem, 1vw + 0.9rem, 1.1875rem);
		color: var(--color-muted);
		max-width: 38ch;
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-lg);
		margin-top: var(--space-sm);
	}

	@media (min-width: 56rem) {
		.hero__grid {
			grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
			gap: clamp(2rem, 5vw, 4.5rem);
		}

		.hero__media {
			order: -1;
		}
	}
</style>
